generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  ADMIN
}

enum LessonType {
  TEXT
  VIDEO
  PDF
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model User {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  telegramId   BigInt           @unique @map("telegram_id")
  firstName    String?          @map("first_name")
  lastName     String?          @map("last_name")
  username     String?
  role         UserRole         @default(STUDENT)
  isPremium    Boolean          @default(false) @map("is_premium")
  premiumUntil DateTime?        @map("premium_until") @db.Timestamptz(6)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  progress     LessonProgress[]
  attempts     QuizAttempt[]

  @@map("users")
}

model Course {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String   @unique
  title       String
  description String?
  imageUrl    String?  @map("image_url")
  isPremium   Boolean  @default(false) @map("is_premium")
  isPublished Boolean  @default(false) @map("is_published")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  lessons     Lesson[]

  @@map("courses")
}

model Lesson {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId    String           @map("course_id") @db.Uuid
  slug        String
  title       String
  description String?
  type        LessonType       @default(TEXT)
  content     String?
  mediaUrl    String?          @map("media_url")
  duration    Int?
  isPreview   Boolean          @default(false) @map("is_preview")
  isPublished Boolean          @default(false) @map("is_published")
  order       Int              @default(0)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quiz        Quiz?
  progress    LessonProgress[]

  @@unique([courseId, slug])
  @@index([courseId, order])
  @@map("lessons")
}

model LessonProgress {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  lessonId    String         @map("lesson_id") @db.Uuid
  status      ProgressStatus @default(NOT_STARTED)
  completedAt DateTime?      @map("completed_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model Quiz {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonId  String        @unique @map("lesson_id") @db.Uuid
  title     String
  passScore Int           @default(70) @map("pass_score")
  lesson    Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model Question {
  id      String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quizId  String         @map("quiz_id") @db.Uuid
  text    String
  order   Int            @default(0)
  quiz    Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options AnswerOption[]

  @@index([quizId, order])
  @@map("questions")
}

model AnswerOption {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId String   @map("question_id") @db.Uuid
  text       String
  isCorrect  Boolean  @default(false) @map("is_correct")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("answer_options")
}

model QuizAttempt {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  quizId      String   @map("quiz_id") @db.Uuid
  score       Int
  passed      Boolean
  submittedAt DateTime @default(now()) @map("submitted_at") @db.Timestamptz(6)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId, quizId])
  @@map("quiz_attempts")
}
